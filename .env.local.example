# Local development only (do not use for Cloud Run deploy)

# LLM provider
# - auto: 優先使用 ANTHROPIC_API_KEY，若沒有則改用 GROQ_API_KEY/GROQ_KEY_FILE
# - anthropic: 強制使用 Anthropic
# - groq: 強制使用 Groq
LLM_PROVIDER=auto

# Anthropic (optional in local)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_FAST=claude-sonnet-4-6
ANTHROPIC_MODEL_STRONG=claude-opus-4-6

# Groq (for local fallback)
GROQ_API_KEY=
GROQ_KEY_FILE=../groq.key
GROQ_API_BASE=https://api.groq.com/openai/v1
GROQ_MODEL_FAST=llama-3.3-70b-versatile
GROQ_MODEL_STRONG=llama-3.3-70b-versatile

# Optional (only needed when generating Gamma presentation)
GAMMA_API_KEY=
GAMMA_THEME_ID=

# Local server options
LOCAL_HOST=127.0.0.1
LOCAL_PORT=8080
